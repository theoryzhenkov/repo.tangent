# HTTP
PORT=8787

# Postgres (Fedify durable KV+queue and app data live here)
DATABASE_URL=postgres://tangent:tangent@localhost:5432/tangent

# Identity (split-domain: WebFinger handle host vs. ActivityPub server origin)
HANDLE_HOST=theor.net
AP_ORIGIN=https://ap.theor.net
ACTOR_HANDLE=theor

# Compose endpoint (CLI). If unset, POST /api/compose is disabled.
COMPOSE_TOKEN=

# Bluesky POSSE. Syndication is enabled only when identifier + app password are set.
BLUESKY_SERVICE=https://bsky.social
BLUESKY_IDENTIFIER=theor.net
BLUESKY_APP_PASSWORD=

# Public note permalink base, linked from syndicated Bluesky posts (optional).
NOTE_PERMALINK_BASE=https://theor.net/notes

# Logging
LOG_LEVEL=info
